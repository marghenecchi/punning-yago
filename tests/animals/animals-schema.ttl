@prefix ex:   <http://example.org/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

# ── Classes ───────────────────────────────────────────────────────────────────

ex:Animal              rdf:type  rdfs:Class .
ex:Taxon               rdf:type  rdfs:Class .
ex:ConservationStatus  rdf:type  rdfs:Class .

# ── Properties ────────────────────────────────────────────────────────────────

# generic-sentence properties (about the kind)
ex:eats     rdfs:domain  ex:Animal ;
            rdfs:range   ex:Animal .

ex:livesIn  rdfs:domain  ex:Animal .

# predator-prey property — mirrors yago:consumes (wdt:P1034), domain/range Taxon
# this is why it survives in YAGO for taxa
ex:consumes  rdfs:domain  ex:Taxon ;
             rdfs:range   ex:Taxon .

# entity-level properties (about the taxon as a named entity)
ex:parentTaxon         rdfs:domain  ex:Taxon ;
                       rdfs:range   ex:Taxon .

ex:conservationStatus  rdfs:domain  ex:Taxon ;
                       rdfs:range   ex:ConservationStatus .
