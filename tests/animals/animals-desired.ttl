@prefix ex:   <http://example.org/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-syntax-ns#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ── Taxonomy (class hierarchy) ────────────────────────────────────────────────

ex:Canidae      rdf:type  owl:Class ; rdfs:subClassOf ex:Animal .
ex:Canis        rdf:type  owl:Class ; rdfs:subClassOf ex:Canidae .
ex:Canis_lupus  rdf:type  owl:Class ; rdfs:subClassOf ex:Canis .

# ── Canis_lupus as individual (punning) ───────────────────────────────────────

# Entity facts (UC1 in animals.md: entity-level facts on the taxon)
ex:Canis_lupus  rdf:type               ex:Taxon ;
                ex:parentTaxon         ex:Canis ;
                ex:conservationStatus  ex:LeastConcern .

# Generic sentences (UC2 in animals.md: facts true of the kind, not every individual)
ex:Canis_lupus  ex:eats    ex:Deer ;
                ex:livesIn ex:Forest .

# ── Individual wolf (UC1: individual typing) ──────────────────────────────────

ex:Tito  rdf:type     ex:Canis_lupus ;
         ex:locatedIn ex:RomeZoo .
